---
import { Image } from 'astro:assets';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import PasswordGate from '../../components/PasswordGate.astro';
import { getCollection } from 'astro:content';

const allPosts = (await getCollection('projects')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);

const published = allPosts.filter(p => !p.data.draft);
const drafts = allPosts.filter(p => p.data.draft);
---

<BaseLayout title="Projects in Progress | Christopher Olberding" description="Work in progress — projects shared selectively." noindex>
  <Header variant="page" />
  <div class="page-top-border" aria-hidden="true"></div>
  <div class="scroll-progress scroll-progress--left" aria-hidden="true"></div>
  <div class="scroll-progress scroll-progress--right" aria-hidden="true"></div>

  <PasswordGate>
    <main class="projects">
      <header class="projects__header">
        <h1 class="projects__title">Projects in Progress</h1>
      </header>

      <section class="projects__gallery">
        {published.map((post) => (
          <a href={`/projects/${post.id}`} class="gallery-card">
            <div class="gallery-card__image-wrap">
              {post.data.cardImage ? (
                <Image
                  src={post.data.cardImage}
                  alt=""
                  class="gallery-card__image"
                  style={post.data.cardImagePosition ? `object-position: ${post.data.cardImagePosition}` : undefined}
                  widths={[400, 600]}
                  sizes="(max-width: 700px) calc(100vw - 4rem), 460px"
                />
              ) : (
                <div class="gallery-card__placeholder" aria-hidden="true">
                  <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M12 19V5M5 12l7-7 7 7" />
                  </svg>
                </div>
              )}
            </div>
            <div class="gallery-card__body">
              <h2 class="gallery-card__title">{post.data.title}</h2>
              {post.data.description && <p class="gallery-card__description">{post.data.description}</p>}
            </div>
          </a>
        ))}
      </section>

      {published.length === 0 && !drafts.length && (
        <p class="projects__empty">Nothing here yet. Check back soon.</p>
      )}

      {drafts.length > 0 && (
        <section class="projects__drafts">
          <h2 class="projects__section-label">In Development</h2>
          {drafts.map((post) => (
            <article class="draft-card">
              <h3 class="draft-card__title">{post.data.title}</h3>
              {post.data.description && <p class="draft-card__description">{post.data.description}</p>}
            </article>
          ))}
        </section>
      )}
    </main>
  </PasswordGate>

  <div class="page-bottom-border" aria-hidden="true"></div>
</BaseLayout>

<script>
  document.addEventListener('astro:page-load', () => {
    const bars = document.querySelectorAll('.scroll-progress') as NodeListOf<HTMLElement>;
    if (bars.length) {
      function updateProgress() {
        const scrollTop = window.scrollY;
        const docHeight = document.documentElement.scrollHeight - window.innerHeight;
        const pct = docHeight > 0 ? Math.min(scrollTop / docHeight, 1) : 0;
        bars.forEach(bar => { bar.style.transform = `scaleY(${pct})`; });
      }
      window.addEventListener('scroll', updateProgress, { passive: true });
      updateProgress();
    }
  });
</script>

<style>
  .page-top-border {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 10px;
    background-color: var(--color-accent);
    z-index: 400;
    pointer-events: none;
  }

  .page-bottom-border {
    width: 100%;
    height: 10px;
    background-color: var(--color-accent);
  }

  .scroll-progress {
    position: fixed;
    top: 0;
    width: 10px;
    height: 100%;
    background-color: var(--color-accent);
    transform-origin: top;
    transform: scaleY(0);
    z-index: 400;
    pointer-events: none;
  }

  .scroll-progress--left { left: 0; }
  .scroll-progress--right { right: 0; }

  .projects {
    max-width: 1000px;
    margin: 0 auto;
    padding: 6rem var(--spacing-md) var(--spacing-xl);
  }

  .projects__header {
    margin-bottom: var(--spacing-lg);
  }

  .projects__title {
    font-family: 'Outfit', var(--font-sans);
    font-size: 2.4rem;
    font-weight: 800;
    letter-spacing: -0.03em;
    line-height: 1.1;
    color: var(--color-text);
  }

  .projects__gallery {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--spacing-md);
  }

  @media (max-width: 700px) {
    .projects__gallery {
      grid-template-columns: 1fr;
    }
  }

  /* Gallery card */
  .gallery-card {
    text-decoration: none;
    display: flex;
    flex-direction: column;
    border-radius: 4px;
    overflow: hidden;
    background: #fff;
    box-shadow: 0 1px 8px rgba(0, 0, 0, 0.06);
    transition: box-shadow 0.2s, transform 0.2s;
  }

  .gallery-card:hover {
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.1);
    transform: translateY(-2px);
  }

  .gallery-card__image-wrap {
    overflow: hidden;
    aspect-ratio: 16 / 10;
    background: var(--color-accent);
  }

  .gallery-card__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top;
    transition: transform 0.3s ease;
  }

  .gallery-card:hover .gallery-card__image {
    transform: scale(1.03);
  }

  .gallery-card__placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-accent-text);
    opacity: 0.4;
  }

  .gallery-card__body {
    padding: 1.2rem 1.4rem 1.4rem;
  }

  .gallery-card__date {
    display: block;
    font-family: 'Outfit', var(--font-sans);
    font-size: 0.6rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-accent-text);
    margin-bottom: 0.3em;
  }

  .gallery-card__title {
    font-family: 'Outfit', var(--font-sans);
    font-size: 1.3rem;
    font-weight: 700;
    line-height: 1.2;
    letter-spacing: -0.02em;
    color: var(--color-text);
    transition: color 0.2s;
  }

  .gallery-card:hover .gallery-card__title {
    color: var(--color-accent-text);
  }

  .gallery-card__description {
    font-family: 'Literata', var(--font-serif);
    font-size: 0.85rem;
    color: var(--color-text-light);
    line-height: 1.5;
    margin-top: 0.4em;
  }

  .projects__empty {
    font-family: 'Literata', var(--font-serif);
    font-size: 1rem;
    color: var(--color-text-light);
    font-style: italic;
  }

  .projects__section-label {
    font-family: 'Outfit', var(--font-sans);
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-accent-text);
    padding-top: 3.5rem;
    margin-bottom: 1.5rem;
    border-top: 10px solid var(--color-accent);
    margin-top: 0;
  }

  .draft-card {
    margin-bottom: var(--spacing-md);
    opacity: 0.6;
  }

  .draft-card__title {
    font-family: 'Outfit', var(--font-sans);
    font-size: 1.3rem;
    font-weight: 700;
    line-height: 1.2;
    letter-spacing: -0.02em;
    color: var(--color-text);
  }

  .draft-card__description {
    font-family: 'Literata', var(--font-serif);
    font-size: 0.85rem;
    color: var(--color-text-light);
    line-height: 1.5;
    margin-top: 0.3em;
  }
</style>
