---
import { encrypt } from '../utils/crypto';

const PASSWORD = 'tangerine';
const STORAGE_KEY = 'projects-auth';

const slotContent = await Astro.slots.render('default');
const encrypted = await encrypt(slotContent, PASSWORD);
---

<div class="pw-gate" id="pw-gate" data-storage-key={STORAGE_KEY}>
  <div class="pw-gate__inner">
    <h2 class="pw-gate__title">Projects in Progress</h2>
    <p class="pw-gate__description">This section contains work in progress and is shared selectively. Enter the password to continue.</p>
    <form class="pw-gate__form" id="pw-gate-form">
      <label class="pw-gate__label">
        Password
        <input type="password" class="pw-gate__input" id="pw-gate-input" autocomplete="off" autofocus />
      </label>
      <button type="submit" class="pw-gate__submit">Enter</button>
      <p class="pw-gate__error" id="pw-gate-error" aria-live="polite"></p>
    </form>
  </div>
</div>

<template id="pw-encrypted" data-content={encrypted}></template>
<div id="pw-content"></div>

<script>
  import { decrypt } from '../utils/crypto';

  document.addEventListener('astro:page-load', async () => {
    const gate = document.getElementById('pw-gate') as HTMLElement | null;
    const contentEl = document.getElementById('pw-content');
    const tmpl = document.getElementById('pw-encrypted') as HTMLTemplateElement | null;
    const form = document.getElementById('pw-gate-form');
    const input = document.getElementById('pw-gate-input') as HTMLInputElement | null;
    const error = document.getElementById('pw-gate-error');

    if (!gate || !contentEl || !tmpl) return;

    const storageKey = gate.dataset.storageKey || 'projects-auth';
    const encrypted = tmpl.dataset.content;
    if (!encrypted) return;

    // Check if already authed this session
    const savedPassword = sessionStorage.getItem(storageKey);
    if (savedPassword) {
      try {
        const html = await decrypt(encrypted, savedPassword);
        contentEl.innerHTML = html;
        gate.remove();
        tmpl.remove();
        return;
      } catch {
        // Stored password no longer valid, clear it
        sessionStorage.removeItem(storageKey);
      }
    }

    form?.addEventListener('submit', async (e) => {
      e.preventDefault();
      if (!input?.value) return;

      const submitBtn = form.querySelector('.pw-gate__submit') as HTMLButtonElement | null;
      if (submitBtn) {
        submitBtn.disabled = true;
        submitBtn.textContent = 'Checking...';
      }

      try {
        const html = await decrypt(encrypted, input.value);
        // Success — store password and reveal content
        sessionStorage.setItem(storageKey, input.value);
        contentEl.innerHTML = html;
        gate.remove();
        tmpl.remove();
      } catch {
        // Decryption failed = wrong password
        if (error) error.textContent = 'Incorrect password';
        input.value = '';
        input.focus();
      }

      if (submitBtn) {
        submitBtn.disabled = false;
        submitBtn.textContent = 'Enter';
      }
    });
  });
</script>

<style>
  .pw-gate {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: var(--color-bg);
    z-index: 9999;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: inset 10px 0 0 0 var(--color-accent),
                inset -10px 0 0 0 var(--color-accent),
                inset 0 10px 0 0 var(--color-accent),
                inset 0 -10px 0 0 var(--color-accent);
  }

  .pw-gate__inner {
    width: 100%;
    max-width: 400px;
    padding: 0 var(--spacing-md);
  }

  .pw-gate__title {
    font-family: 'Outfit', var(--font-sans);
    font-size: 2rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    color: var(--color-text);
    margin-bottom: 0.5rem;
    position: relative;
  }

  .pw-gate__title::before {
    content: '';
    position: absolute;
    top: 0;
    left: -2.5rem;
    width: 10px;
    height: 100%;
    background-color: var(--color-accent);
  }

  @media (max-width: 640px) {
    .pw-gate__title::before {
      display: none;
    }
  }

  .pw-gate__description {
    font-family: 'Literata', var(--font-serif);
    font-size: 0.95rem;
    color: var(--color-text-light);
    line-height: 1.5;
    margin-bottom: var(--spacing-md);
  }

  .pw-gate__label {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    font-family: 'Outfit', var(--font-sans);
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-text);
    margin-bottom: var(--spacing-sm);
  }

  .pw-gate__input {
    flex-basis: 100%;
    width: 100%;
    font-family: 'Literata', var(--font-serif);
    font-size: 0.9rem;
    padding: 0.6em;
    margin-top: 0.3em;
    border: 1px solid rgba(0, 0, 0, 0.15);
    background: var(--color-bg);
    color: var(--color-text);
    border-radius: 0;
    outline: none;
    transition: border-color 0.2s;
  }

  .pw-gate__input:focus {
    border-color: var(--color-accent);
  }

  .pw-gate__submit {
    font-family: 'Outfit', var(--font-sans);
    font-size: 0.85rem;
    font-weight: 700;
    padding: 0.7em 1.8em;
    background: var(--color-text);
    color: var(--color-bg);
    border: none;
    cursor: pointer;
    transition: background 0.2s;
    margin-top: var(--spacing-sm);
  }

  .pw-gate__submit:hover {
    background: var(--color-accent-text);
  }

  .pw-gate__submit:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  .pw-gate__error {
    font-family: 'Outfit', var(--font-sans);
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-accent-text);
    margin-top: 0.5rem;
    min-height: 1.2em;
  }
</style>
